# Compiler files - ignore
cache/
out/

# Foundry specific - ignore
lcov.info
*.gas-snapshot
*.coverage

# Test coverage - ignore
coverage/
coverage.json

# Logs - ignore
*.log
logs/

# Environment files - ignore
.env

# OS files - ignore
.DS_Store
Thumbs.db

# IDE - ignore
.vscode/
.idea/
*.swp

